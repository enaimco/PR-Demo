# GitHub OAuth App credentials
# Create an OAuth App at https://github.com/settings/developers
GITHUB_CLIENT_ID=your_github_oauth_app_client_id
GITHUB_CLIENT_SECRET=your_github_oauth_app_client_secret

# Default GitHub organisation (optional — can be set per-request in Phase 2)
GITHUB_ORG=your_github_org_name

# Random string used to sign session cookies (generate with: openssl rand -hex 32)
SESSION_SECRET=change_me_to_a_random_string
